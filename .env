# ─────────────────────────────────────────────────────────────────
# Geospatial Pipeline - Environment Variables
# ─────────────────────────────────────────────────────────────────

# MQTT
MQTT_BROKER=tcp://localhost:1883
MQTT_TOPIC=gps/drivers

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_RAW=raw.gps.events
KAFKA_TOPIC_ENRICHED=enriched.gps.events
KAFKA_TOPIC_TRIPS=trip.lifecycle.events
KAFKA_TOPIC_ANOMALY=anomaly.events

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=geodata
CLICKHOUSE_USER=geo_user
CLICKHOUSE_PASSWORD=geo_pass

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# MinIO
MINIO_ENDPOINT=localhost:9010
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=geo-raw

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# Simulator
NUM_DRIVERS=100
EMIT_INTERVAL_S=3

# API
API_PORT=8080

# ─────────────────────────────────────────────────────────────────
# Service UIs (for reference)
# ─────────────────────────────────────────────────────────────────
# Kafka UI:       http://localhost:8090
# Flink UI:       http://localhost:8081
# ClickHouse:     http://localhost:8123/play
# MinIO:          http://localhost:9011
# MLflow:         http://localhost:5000
# Grafana:        http://localhost:3001  (admin/admin123)
# Prometheus:     http://localhost:9090